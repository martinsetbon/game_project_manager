<div class="new-dashboard">
  <!-- Page Title -->
  <div class="page-title">
    <h1>Projects</h1>
  </div>

  <!-- My Projects Section -->
  <% if @owned_projects.any? %>
    <div class="projects-section">
      <h2>My Projects</h2>
      <div class="projects-grid">
        <% @owned_projects.each do |project| %>
          <div class="project-card owned-project">
            <!-- Status Badge (Top Right) -->
            <div class="project-status">
              <% if project.end_date && project.end_date < Date.today %>
                <span class="status-badge finished">Finished</span>
              <% else %>
                <span class="status-badge active">Active</span>
              <% end %>
            </div>
            
            <!-- Project Name -->
            <h3 class="project-name"><%= project.name %></h3>
            
            <!-- Description -->
            <p class="project-description"><%= project.description || 'No description' %></p>
            
            <!-- Budget (Only for owned projects) -->
            <% if project.budget.present? %>
              <div class="project-budget">
                <strong>Budget:</strong> <%= project.currency || 'USD' %> <%= project.budget %>
              </div>
            <% end %>
            
            <!-- Dates -->
            <div class="project-dates">
              <% if project.start_date %>
                <div class="date-item">
                  <i class="bi bi-calendar"></i>
                  <span><strong>Start:</strong> <%= project.start_date.strftime('%Y-%m-%d') %></span>
                </div>
              <% end %>
              <% if project.end_date %>
                <div class="date-item">
                  <i class="bi bi-calendar"></i>
                  <span><strong>End:</strong> <%= project.end_date.strftime('%Y-%m-%d') %></span>
                </div>
              <% end %>
            </div>
            
            <!-- Action Buttons -->
            <div class="project-actions">
              <!-- Enter Button (Bottom Left) -->
              <%= link_to project_path(project), class: "enter-project-btn" do %>
                <i class="bi bi-arrow-right-circle"></i>
                <span>Enter</span>
              <% end %>
              
              <!-- Delete Button (Bottom Right - Only for owned projects) -->
              <%= link_to project_path(project), 
                  method: :delete, 
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this project?" },
                  class: "delete-project-btn" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Contributing Projects Section -->
  <% if @contributed_projects.any? %>
    <div class="projects-section">
      <h2>Projects I'm Contributing To</h2>
      <div class="projects-grid">
        <% @contributed_projects.each do |project| %>
          <div class="project-card contributing-project">
            <!-- Status Badge (Top Right) -->
            <div class="project-status">
              <% if project.end_date && project.end_date < Date.today %>
                <span class="status-badge finished">Finished</span>
              <% else %>
                <span class="status-badge active">Active</span>
              <% end %>
            </div>
            
            <!-- Project Name -->
            <h3 class="project-name"><%= project.name %></h3>
            
            <!-- Description -->
            <p class="project-description"><%= project.description || 'No description' %></p>
            
            <!-- Dates -->
            <div class="project-dates">
              <% if project.start_date %>
                <div class="date-item">
                  <i class="bi bi-calendar"></i>
                  <span><strong>Start:</strong> <%= project.start_date.strftime('%Y-%m-%d') %></span>
                </div>
              <% end %>
              <% if project.end_date %>
                <div class="date-item">
                  <i class="bi bi-calendar"></i>
                  <span><strong>End:</strong> <%= project.end_date.strftime('%Y-%m-%d') %></span>
                </div>
              <% end %>
            </div>
            
            <!-- Action Buttons -->
            <div class="project-actions">
              <!-- Enter Button (Bottom Left) -->
              <%= link_to project_path(project), class: "enter-project-btn" do %>
                <i class="bi bi-arrow-right-circle"></i>
                <span>Enter</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Empty State -->
  <% if @owned_projects.empty? && @contributed_projects.empty? %>
    <div class="projects-empty-state">
      <h3>No projects yet</h3>
      <p>Create your first project or wait to be added to one!</p>
      <%= link_to 'Create New Project', new_project_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
