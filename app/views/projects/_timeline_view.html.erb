<div class="timeline-container" data-controller="timeline" 
     data-timeline-project-id-value="<%= project.id %>"
     data-timeline-current-year-value="2025"
     data-timeline-current-month-value="1">
  
  <!-- Timeline Header -->
  <div class="timeline-header">
    <div class="timeline-title-section">
      <h3 class="timeline-title">Project Timeline</h3>
      <span class="timeline-zoom-indicator" data-timeline-target="zoomIndicator">Year View</span>
    </div>
    
    <!-- Navigation Controls -->
    <div class="timeline-navigation">
      <button class="btn btn-outline-secondary btn-sm" data-action="timeline#previousYear">
        <i class="bi bi-chevron-left"></i>
      </button>
      
      <h4 class="timeline-period" data-timeline-target="periodTitle" data-action="click->timeline#zoomToYear">
        2025
      </h4>
      
      <button class="btn btn-outline-secondary btn-sm" data-action="timeline#nextYear">
        <i class="bi bi-chevron-right"></i>
      </button>
    </div>
  </div>

  <!-- Timeline Content -->
  <div class="timeline-content" data-timeline-target="content">
    <!-- Year View -->
    <div class="timeline-year-view" data-timeline-target="yearView">
      <div class="timeline-grid">
        <!-- Month Headers -->
        <div class="timeline-header-row">
          <div class="timeline-row-label">Contributors</div>
          <% (1..12).each do |month| %>
            <div class="timeline-header-cell" 
                 data-month="<%= month %>"
                 data-action="click->timeline#zoomToMonth"
                 data-month-number="<%= month %>">
              <%= Date::MONTHNAMES[month] %>
            </div>
          <% end %>
        </div>

        <!-- Contributor Rows -->
        <% 
          # Get all unique responsible contributors
          responsible_contributors = project.project_features
            .joins(:responsible_assignments)
            .includes(:responsible_assignments, :responsible_contributors)
            .map(&:responsible_contributors)
            .flatten
            .uniq
          
          # Add unassigned features
          unassigned_features = project.project_features
            .left_joins(:responsible_assignments)
            .where(feature_assignments: { id: nil })
          
          all_contributors = responsible_contributors + (unassigned_features.any? ? [nil] : [])
        %>
        
        <% all_contributors.each do |contributor| %>
          <div class="timeline-row" data-contributor-id="<%= contributor&.id || 'unassigned' %>">
            <!-- Contributor Label -->
            <div class="timeline-row-label">
              <%= contributor&.name || 'Unassigned' %>
            </div>
            
            <!-- Month Area (where feature bars will be positioned) -->
            <div class="timeline-month-area" data-contributor-id="<%= contributor&.id || 'unassigned' %>">
              <!-- Feature bars will be absolutely positioned here -->
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Month View -->
    <div class="timeline-month-view d-none" data-timeline-target="monthView">
      <div class="timeline-grid">
        <!-- Day Headers -->
        <div class="timeline-header-row">
          <div class="timeline-row-label">Contributors</div>
          <% (1..31).each do |day| %>
            <div class="timeline-header-cell" data-day="<%= day %>">
              <%= sprintf("%02d", day) %>
            </div>
          <% end %>
        </div>

        <!-- Contributor Rows -->
        <% all_contributors.each do |contributor| %>
          <div class="timeline-row" data-contributor-id="<%= contributor&.id || 'unassigned' %>">
            <!-- Contributor Label -->
            <div class="timeline-row-label">
              <%= contributor&.name || 'Unassigned' %>
            </div>
            
            <!-- Day Area (where feature bars will be positioned) -->
            <div class="timeline-day-area" data-contributor-id="<%= contributor&.id || 'unassigned' %>">
              <!-- Feature bars will be absolutely positioned here -->
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
