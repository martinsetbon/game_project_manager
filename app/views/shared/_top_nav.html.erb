<div class="top-nav">
  <div class="top-nav-content">
    <!-- Light Mode Button -->
    <div class="light-mode-section">
      <%= link_to "#", class: "light-mode-btn", id: "light-mode-toggle" do %>
        <i class="bi bi-sun"></i>
        <span>Light Mode</span>
      <% end %>
    </div>

    <!-- User Welcome Section -->
    <div class="user-welcome">
      <%= link_to profile_path, class: "user-info" do %>
        <span class="welcome-text">Welcome, <%= current_user.name || current_user.email %></span>
        <div class="user-avatar">
          <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "avatar", alt: "user avatar" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
