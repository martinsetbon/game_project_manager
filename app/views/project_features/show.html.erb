<div class="new-dashboard feature-show-page">
  <div class="page-title" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
    <div>
      <p class="small text-secondary mb-0 d-flex flex-wrap align-items-center gap-2">
        <span class="feature-status-badge status-<%= @project_feature.status %>">
          <% if @project_feature.status == 'work_in_progress' %>
            On Going
          <% elsif @project_feature.status == 'stand_by' %>
            Stand By
          <% else %>
            <%= @project_feature.status.humanize %>
          <% end %>
        </span>
        <% if @project_feature.start_date.present? || @project_feature.end_date.present? %>
          <span>
            <%= @project_feature.start_date&.strftime('%Y-%m-%d') || '—' %>
            –
            <%= @project_feature.end_date&.strftime('%Y-%m-%d') || '—' %>
          </span>
        <% end %>
        <% if @project_feature.overdue? %>
          <span class="badge bg-danger">Overdue</span>
        <% end %>
      </p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-center">
      <%= link_to project_path(@project), class: 'btn btn-outline-secondary btn-sm' do %>
        <i class="bi bi-arrow-left"></i> Project
      <% end %>
      <%= link_to project_project_features_path(@project), class: 'btn btn-outline-secondary btn-sm' do %>
        All features
      <% end %>
      <% if @is_project_creator %>
        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal_<%= @project_feature.id %>">
          <i class="bi bi-trash"></i> Delete
        </button>
      <% end %>
    </div>
  </div>

  <div class="feature-folder-content mt-4">
    <% if flash.now[:overlap_details].present? %>
      <div class="alert alert-warning">
        <strong>Overlapping work detected.</strong> Submit again to save anyway, or adjust dates and assignees.
        <pre class="small text-white mt-2 mb-0" style="white-space: pre-wrap;"><%= flash.now[:overlap_details] %></pre>
      </div>
    <% end %>
    <% if flash.now[:alert].present? %>
      <div class="alert alert-danger"><%= flash.now[:alert] %></div>
    <% end %>
    <% if @project_feature.errors.any? %>
      <div class="alert alert-danger">
        <%= @project_feature.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <% if @project_feature.can_edit_details?(current_user) %>
      <div class="project-info-field mb-3" data-controller="inline-edit" data-field="name">
        <div class="field-display">
          <div class="field-label">
            <i class="bi bi-pencil-square edit-icon" data-action="click->inline-edit#edit"></i>
            <span>Name</span>
          </div>
          <div class="field-separator"></div>
          <div class="field-value"><%= @project_feature.name %></div>
        </div>
        <div class="field-edit" style="display: none;">
          <input type="text" class="form-control" value="<%= @project_feature.name %>" data-inline-edit-target="input">
          <button class="btn btn-sm btn-primary save-btn" data-action="click->inline-edit#save">
            <i class="bi bi-check"></i> Save
          </button>
          <button class="btn btn-sm btn-secondary cancel-btn" data-action="click->inline-edit#cancel">
            <i class="bi bi-x"></i> Cancel
          </button>
        </div>
      </div>
    <% elsif @project_feature.can_edit?(current_user) %>
      <p class="fw-semibold mb-3"><%= @project_feature.name %></p>
    <% end %>

    <div class="table-responsive">
      <table class="table table-dark table-hover align-middle">
        <thead>
          <tr>
            <th>Task</th>
            <th>Start</th>
            <th>End</th>
            <th>Status</th>
            <th>Responsible</th>
          </tr>
        </thead>
        <tbody>
          <% if @feature_tasks.any? %>
            <% @feature_tasks.each do |task| %>
              <tr class="priority-<%= task.priority || 'none' %>">
                <td>
                  <%= link_to project_task_path(@project, task), class: 'link-light fw-semibold text-decoration-none' do %>
                    <%= task.name %>
                  <% end %>
                  <% if task.in_backlog? %>
                    <span class="badge bg-secondary ms-1">Backlog</span>
                  <% end %>
                  <% if task.overdue? %>
                    <span class="badge bg-danger ms-1">Overdue</span>
                  <% end %>
                </td>
                <td class="text-nowrap text-secondary"><%= task.start_date&.strftime('%Y-%m-%d') || '—' %></td>
                <td class="text-nowrap text-secondary"><%= task.end_date&.strftime('%Y-%m-%d') || '—' %></td>
                <td>
                  <span class="status-badge <%= task.status %>">
                    <% if task.status == 'work_in_progress' %>
                      On Going
                    <% elsif task.status == 'stand_by' %>
                      Stand By
                    <% else %>
                      <%= task.status.humanize %>
                    <% end %>
                  </span>
                </td>
                <td class="text-secondary small">
                  <%= task.responsible_users.map(&:name).join(', ').presence || '—' %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="text-center text-secondary py-5">
                <i class="bi bi-inbox d-block mb-2" style="font-size: 1.75rem;"></i>
                No tasks in this feature yet.
                <% if @project_feature.can_edit_details?(current_user) %>
                  Use the table below to add tasks.
                <% elsif @project_feature.can_edit?(current_user) %>
                  <%= link_to 'Add a task', new_project_task_path(@project), class: 'link-info' %>.
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @project_feature.can_edit_details?(current_user) %>
      <div class="mt-3">
        <%= button_to save_as_template_project_project_feature_path(@project, @project_feature),
            method: :post,
            class: 'btn btn-outline-info btn-sm',
            form: { data: { turbo_confirm: 'Create a personal template from this feature’s tasks?' } } do %>
          <i class="bi bi-journal-plus"></i> Save as template
        <% end %>
      </div>

      <div class="mt-3"
           data-controller="feature-bulk-form"
           data-feature-bulk-form-row-template-id-value="feature-show-add-tasks-row-template">
        <p class="small text-secondary mb-2">Add new tasks here (one row to start). Leave start and end empty for backlog-only. <strong>Update feature</strong> saves new rows; use <strong>+ Add task row</strong> for more.</p>

        <%= form_with model: [@project, @project_feature], local: true do |f| %>
          <% if @add_tasks_overlap_retry %>
            <%= hidden_field_tag :proceed_overlaps, 'true' %>
          <% end %>

          <div class="table-responsive">
            <table class="table table-dark table-sm align-middle">
              <thead>
                <tr>
                  <th>Task name</th>
                  <th>Start</th>
                  <th>End</th>
                  <th>Responsible</th>
                  <th></th>
                </tr>
              </thead>
              <tbody data-feature-bulk-form-target="tbody">
                <% add_rows = @submitted_add_tasks.presence || Array.new(1) { {} } %>
                <% add_rows.each do |row| %>
                  <tr data-feature-bulk-form-target="row">
                    <td><%= text_field_tag "tasks[][name]", row['name'] || row[:name], class: 'form-control form-control-sm', placeholder: 'Task name' %></td>
                    <td><%= date_field_tag "tasks[][start_date]", row['start_date'] || row[:start_date], class: 'form-control form-control-sm' %></td>
                    <td><%= date_field_tag "tasks[][end_date]", row['end_date'] || row[:end_date], class: 'form-control form-control-sm' %></td>
                    <td>
                      <%= select_tag "tasks[][responsible_user_id]",
                          options_for_select(
                            [['-- Unassigned --', '']] + @contributors.map { |u| [u.name.to_s, u.id] },
                            (row['responsible_user_id'] || row[:responsible_user_id]).presence
                          ),
                          class: 'form-select form-select-sm' %>
                    </td>
                    <td>
                      <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->feature-bulk-form#removeRow">X</button>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
            <button type="button" class="btn btn-outline-light btn-sm" data-action="feature-bulk-form#addRow">+ Add task row</button>
            <%= f.submit(
                  @add_tasks_overlap_retry ? 'Update feature (allow overlaps)' : 'Update feature',
                  class: "btn btn-sm #{@add_tasks_overlap_retry ? 'btn-warning' : 'btn-primary'}"
                ) %>
          </div>
        <% end %>
      </div>

      <template id="feature-show-add-tasks-row-template">
        <tr data-feature-bulk-form-target="row">
          <td><input type="text" name="tasks[][name]" class="form-control form-control-sm" placeholder="Task name"></td>
          <td><input type="date" name="tasks[][start_date]" class="form-control form-control-sm"></td>
          <td><input type="date" name="tasks[][end_date]" class="form-control form-control-sm"></td>
          <td>
            <select name="tasks[][responsible_user_id]" class="form-select form-select-sm">
              <option value="">-- Unassigned --</option>
              <% @contributors.each do |u| %>
                <option value="<%= u.id %>"><%= u.name %></option>
              <% end %>
            </select>
          </td>
          <td><button type="button" class="btn btn-sm btn-outline-danger" data-action="click->feature-bulk-form#removeRow">X</button></td>
        </tr>
      </template>
    <% end %>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal_<%= @project_feature.id %>" tabindex="-1" aria-labelledby="deleteModalLabel_<%= @project_feature.id %>" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteModalLabel_<%= @project_feature.id %>">Delete Feature</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        if you delete a feature, all its tasks will also be deleted, are you sure you want to delete "<%= @project_feature.name %>" ? This action cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <%= simple_form_for [@project, @project_feature],
                           method: :delete,
                           html: { data: { turbo: true } } do |f| %>
          <%= f.button :submit, "Delete", class: "btn btn-danger" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
