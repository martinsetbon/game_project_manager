<div class="new-dashboard">
  <div class="page-title">
    <h1>Create feature from selected tasks</h1>
  </div>

  <div class="feature-folder-content">
    <p class="text-secondary">The following tasks will be grouped under one feature. Their dates and assignments stay as they are.</p>

    <ul class="mb-4">
      <% @tasks.each do |t| %>
        <li><strong><%= t.name %></strong><% if t.start_date && t.end_date %> — <%= t.start_date %> → <%= t.end_date %><% end %></li>
      <% end %>
    </ul>

    <%= form_with url: create_from_tasks_project_project_features_path(@project), method: :post, local: true do %>
      <% @tasks.each do |t| %>
        <%= hidden_field_tag 'task_ids[]', t.id %>
      <% end %>
      <div class="mb-3">
        <%= label_tag 'project_feature_name', 'Feature name', class: 'form-label' %>
        <%= text_field_tag 'project_feature[name]', '', class: 'form-control', required: true, placeholder: 'e.g. Main character' %>
      </div>
      <div class="d-flex gap-2">
        <%= submit_tag 'Create feature', class: 'btn btn-primary' %>
        <%= link_to 'Cancel', project_path(@project), class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>
</div>
