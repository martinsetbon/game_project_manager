<%= link_to project_project_feature_path(project_feature.project, project_feature), class: "text-decoration-none" do %>
  <div id="<%= dom_id project_feature %>" class="card mb-3 hover-shadow">
    <div class="card-body">
      <p class="mb-2">
        <strong>Name:</strong>
        <%= project_feature.name %>
      </p>

      <p class="mb-2">
        <strong>Duration:</strong>
        <%= project_feature.duration %> days
      </p>

      <p class="mb-0">
        <strong>Project:</strong>
        <%= project_feature.project.name %>
      </p>
      
      <% if project_feature.overdue? %>
        <div class="overdue-indicator mt-2" title="This feature's end date is overdue" data-bs-toggle="tooltip" data-bs-placement="top">
          <i class="bi bi-exclamation-circle-fill text-danger"></i>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
